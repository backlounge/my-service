{
  "name": "gyomu-system-lp",
  "private": true,
  "version": "1.0.0",
  "description": "中小企業・個人事業主向け業務システム紹介LP",
  "scripts": {
    "dev": "tailwindcss -i ./src/input.css -o ./public/css/style.css --watch",
    "build": "tailwindcss -i ./src/input.css -o ./public/css/style.css --minify && node scripts/generate-build-info.mjs",
    "pages:dev": "wrangler pages dev public",
    "deploy": "npm run build && wrangler pages deploy public",
    "d1:create": "wrangler d1 create gyomu_system_lp_db",
    "d1:migrate:local": "wrangler d1 execute gyomu_system_lp_db --local --file=./schema.sql",
    "d1:migrate:remote": "wrangler d1 execute gyomu_system_lp_db --remote --file=./schema.sql",
    "create-user": "node scripts/create-user.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "wrangler": "^3.78.0"
  }
}
